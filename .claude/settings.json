{
  "$comment": "Claude Code permissions for cifra. Diego is a non-technical founder who already approves every prompt manually, so 'auto' mode eliminates the friction. The 'deny' list below is the real safety net: it blocks the handful of commands that could actually destroy the repo, exfiltrate secrets, or execute untrusted scripts. See docs/PROTOCOLS.md §12 (or your Claude Code docs) to tweak. Last updated: 2026-04-20 stint 15.",
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(git *)",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(pwd)",
      "Bash(cd *)",
      "Bash(wc *)",
      "Bash(echo *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Edit",
      "Write",
      "Read",
      "Grep",
      "Glob",
      "Agent",
      "WebFetch",
      "WebSearch",
      "TodoWrite",
      "ScheduleWakeup"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -rf $HOME/*)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(chown root *)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(curl * | *sh)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(* | sudo *)",
      "Bash(git push * --force*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard origin/*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -fdx*)",
      "Bash(git branch -D main)",
      "Bash(git branch -D master)",
      "Bash(git push origin :main)",
      "Bash(git push origin :master)",
      "Bash(git config --global *)",
      "Bash(dd if=*)",
      "Bash(mkfs*)",
      "Bash(diskutil *)",
      "Bash(:(){ :|:& };:)",
      "Bash(eval *)",
      "Bash(source /dev/stdin*)"
    ]
  }
}
